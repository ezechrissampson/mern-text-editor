# ---- Server ----
NODE_ENV=development
PORT=5001
API_PREFIX=/api/v1

# ---- Database (existing MERN app connection) ----
MONGO_URI=mongodb://127.0.0.1:27017/app_db

# ---- Redis (optional - autosave/draft caching) ----
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379

# ---- CORS ----
CLIENT_ORIGIN=http://localhost:5173

# ---- Autosave ----
AUTOSAVE_INTERVAL_MS=15000
AUTOSAVE_TTL_SECONDS=86400

# ---- Embeds ----
ALLOWED_IFRAME_HOSTS=www.youtube.com,player.vimeo.com,platform.twitter.com,gist.github.com,codepen.io,open.spotify.com,www.google.com

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
